# Server
PORT=3001

# YouTube Live (your channel ID, e.g. UCxxxxxx)
YOUTUBE_CHANNEL_ID=

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# TTS Engine: "kokoro" or "voicevox"
TTS_ENGINE=kokoro

# Kokoro TTS (docker run -p 8880:8880 ghcr.io/remsky/kokoro-fastapi-cpu:latest)
KOKORO_URL=http://localhost:8880
KOKORO_VOICE=jf_alpha

# VOICEVOX (docker compose up -d)
VOICEVOX_URL=http://localhost:50021
VOICEVOX_SPEAKER=1

# Character prompt
SYSTEM_PROMPT=あなたは元気で明るいVTuberの「あいちゃん」です。視聴者のコメントに楽しく返答してください。短い文で、1-2文程度で返してください。
